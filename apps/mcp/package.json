{
	"name": "@kwartrack/mcp",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"dev": "tsx watch src/server.ts",
		"worker:build": "wrangler deploy --dry-run --outdir dist-worker --config wrangler.jsonc",
		"worker:dev": "wrangler dev --config wrangler.jsonc --port 8787",
		"worker:deploy": "wrangler deploy --config wrangler.jsonc",
		"start": "node dist/server.js",
		"test": "vitest run"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@supabase/supabase-js": "^2.110.7",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"tsx": "^4.20.6",
		"typescript": "~6.0.2",
		"vitest": "^4.1.2",
		"wrangler": "^4.111.0"
	}
}
